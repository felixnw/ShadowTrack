# config.example.py
# Rename this file to config.py and fill in your details

# The URL of the API to call to find the closest planes. We are using adsb.lol's free API. 
# Comment out this line if you would like to use your local dump1090.
ADSB_URL = "https://api.adsb.lol/v2/point/{lat}/{lon}/{range}"

# The IP address of your Raspberry Pi on your local network. 
# Uncomment this line if you'd like to use.
# ADSB_URL = "http://YOUR_PI_IP:8080/data/aircraft.json"

ROUTE_URL = "https://api.adsbdb.com/v0/callsign/{callsign}"

# Your Home Coordinates (used to find the "Closest" plane)
HOME_LAT = 0.0000
HOME_LON = 0.0000

# Minimum altitude (in feet) for a plane to be considered valid
MIN_ALTITUDE = 200

# Range in NM to consider when looking for planes. This is only relevant when using adsb.lol.
RANGE = 50